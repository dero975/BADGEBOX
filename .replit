run = "vite"
entrypoint = "index.html"
hidden = [".config"]
modules = ["nodejs-18", "web"]

[nix]
channel = "stable-23_05"

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "."

[[deployment.rewrites]]
from = "/utenti.html"
to = "/utenti.html"

[[deployment.rewrites]]
from = "/storico.html"
to = "/storico.html"

[[deployment.rewrites]]
from = "/*"
to = "/index.html"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3000

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Aggiorna GitHub e Deploy"
author = 42586508
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git add ."

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git commit -m \"Aggiornamento manuale del progetto\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git push origin main"

[[workflows.workflow]]
name = "Run"
author = 42586508
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "vite"
